# URL do webhook (Make/Zapier) que recebe os leads do formulário de contato.
# Nunca hardcodear essa URL no código — sempre ler via process.env.CONTACT_WEBHOOK_URL.
CONTACT_WEBHOOK_URL=

# URL pública do site, usada em metadata, Open Graph e sitemap (ex: https://vartec.com.br).
NEXT_PUBLIC_SITE_URL=
